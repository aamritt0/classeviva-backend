# Porta su cui gira il server (default: 3000, NON serve su Render)
PORT=3000

# URL del frontend (per CORS in produzione)
# In dev: http://localhost:5173
# In produzione: URL del tuo frontend deployato (es. Vercel, Netlify)
# Esempio: https://classeviva-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
